<UserControl
    x:Class="Nimbus.App.Controls.MetricCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Style="{StaticResource CardStyle}">
        <StackPanel Spacing="14">

            <Grid>
                <Border Width="40" Height="40" CornerRadius="8" HorizontalAlignment="Left"
                        Background="{ThemeResource AccentFillColorDefaultBrush}">
                    <FontIcon Glyph="{x:Bind Metric.Glyph, Mode=OneWay}" FontSize="18"
                              Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" />
                </Border>

                <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <FontIcon FontSize="11"
                              Glyph="{x:Bind Metric.IsPositive, Mode=OneWay, Converter={StaticResource TrendGlyph}}"
                              Foreground="{x:Bind Metric.IsPositive, Mode=OneWay, Converter={StaticResource TrendBrush}}" />
                    <TextBlock Style="{StaticResource CaptionTextBlockStyle}"
                               Text="{x:Bind Metric.ChangePercent, Mode=OneWay, Converter={StaticResource SignedPercent}}"
                               Foreground="{x:Bind Metric.IsPositive, Mode=OneWay, Converter={StaticResource TrendBrush}}" />
                </StackPanel>
            </Grid>

            <TextBlock Text="{x:Bind Metric.Value, Mode=OneWay}"
                       Style="{StaticResource TitleTextBlockStyle}" />
            <TextBlock Text="{x:Bind Metric.Label, Mode=OneWay}"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </StackPanel>
    </Border>
</UserControl>
