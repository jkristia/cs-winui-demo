<Application
    x:Class="Nimbus.App.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:Nimbus.App.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <ResourceDictionary Source="ms-appx:///Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Converters shared across all views. -->
            <conv:BoolToVisibilityConverter x:Key="BoolToVisibility" />
            <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility" />
            <conv:TrendBrushConverter x:Key="TrendBrush" />
            <conv:TrendGlyphConverter x:Key="TrendGlyph" />
            <conv:SignedPercentConverter x:Key="SignedPercent" />
            <conv:PercentConverter x:Key="Percent" />
            <conv:ActivityGlyphConverter x:Key="ActivityGlyph" />
            <conv:ProjectStatusTextConverter x:Key="StatusText" />
            <conv:ProjectStatusBrushConverter x:Key="StatusBrush" />
            <conv:ShortTimestampConverter x:Key="ShortTimestamp" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
