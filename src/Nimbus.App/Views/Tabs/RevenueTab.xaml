<UserControl
    x:Class="Nimbus.App.Views.Tabs.RevenueTab"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:tabsvm="using:Nimbus.App.ViewModels.Tabs">

    <Border Style="{StaticResource CardStyle}" VerticalAlignment="Top">
        <StackPanel Spacing="24">
            <StackPanel Spacing="4">
                <TextBlock Text="Monthly revenue" Style="{StaticResource SubtitleTextBlockStyle}" />
                <TextBlock Text="Last six months, USD" Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <ItemsRepeater ItemsSource="{Binding Bars}" HorizontalAlignment="Left" VerticalAlignment="Bottom">
                <ItemsRepeater.Layout>
                    <StackLayout Orientation="Horizontal" Spacing="22" />
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="tabsvm:RevenueBar">
                        <Grid Width="60" Height="244">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" VerticalAlignment="Bottom" Spacing="8">
                                <TextBlock Text="{x:Bind DisplayValue}" Style="{StaticResource CaptionTextBlockStyle}"
                                           HorizontalAlignment="Center"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <Border Height="{x:Bind BarHeight}" CornerRadius="6,6,0,0"
                                        Background="{ThemeResource AccentFillColorDefaultBrush}" />
                            </StackPanel>
                            <TextBlock Grid.Row="1" Text="{x:Bind Label}" Margin="0,8,0,0"
                                       HorizontalAlignment="Center"
                                       Style="{StaticResource CaptionTextBlockStyle}" />
                        </Grid>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>
        </StackPanel>
    </Border>
</UserControl>
