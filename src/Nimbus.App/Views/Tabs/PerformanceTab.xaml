<UserControl
    x:Class="Nimbus.App.Views.Tabs.PerformanceTab"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:tabsvm="using:Nimbus.App.ViewModels.Tabs">

    <Border Style="{StaticResource CardStyle}" VerticalAlignment="Top">
        <StackPanel Spacing="8">
            <StackPanel Spacing="4" Margin="0,0,0,8">
                <TextBlock Text="Service health" Style="{StaticResource SubtitleTextBlockStyle}" />
                <TextBlock Text="Uptime and latency over the last 24 hours"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <ItemsRepeater ItemsSource="{Binding Services}">
                <ItemsRepeater.Layout>
                    <StackLayout Spacing="4" />
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="tabsvm:ServiceRow">
                        <Grid Padding="0,12" ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Spacing="8">
                                <Grid>
                                    <TextBlock Text="{x:Bind Name}" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Right" VerticalAlignment="Center">
                                        <Border Width="8" Height="8" CornerRadius="4" VerticalAlignment="Center"
                                                Background="{x:Bind IsHealthy, Converter={StaticResource TrendBrush}}" />
                                        <TextBlock Text="{x:Bind StatusText}" Style="{StaticResource CaptionTextBlockStyle}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{x:Bind IsHealthy, Converter={StaticResource TrendBrush}}" />
                                    </StackPanel>
                                </Grid>
                                <ProgressBar Maximum="100" Value="{x:Bind UptimePercent}" />
                                <TextBlock Text="{x:Bind UptimeText}" Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                                <TextBlock Text="{x:Bind LatencyText}" Style="{StaticResource TitleTextBlockStyle}"
                                           HorizontalAlignment="Right" />
                                <TextBlock Text="latency" Style="{StaticResource CaptionTextBlockStyle}"
                                           HorizontalAlignment="Right"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>
        </StackPanel>
    </Border>
</UserControl>
