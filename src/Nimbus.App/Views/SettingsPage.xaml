<Page
    x:Class="Nimbus.App.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Nimbus.App.Controls">

    <ScrollViewer>
        <StackPanel Padding="36,28,36,36" Spacing="12" MaxWidth="900" HorizontalAlignment="Left">

            <StackPanel Spacing="4" Margin="0,0,0,8">
                <TextBlock Text="Settings" Style="{StaticResource PageTitleStyle}" />
                <TextBlock Text="Personalise how Nimbus looks and behaves."
                           Style="{StaticResource BodyTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <TextBlock Text="Appearance" Style="{StaticResource SectionHeaderStyle}" Margin="0,8,0,0" />

            <controls:SettingRow Glyph="&#xE713;" Header="App theme"
                                 Description="Choose how Nimbus follows light or dark mode.">
                <ComboBox MinWidth="190" SelectedIndex="{x:Bind ViewModel.SelectedThemeIndex, Mode=TwoWay}">
                    <ComboBoxItem Content="Use system setting" />
                    <ComboBoxItem Content="Light" />
                    <ComboBoxItem Content="Dark" />
                </ComboBox>
            </controls:SettingRow>

            <controls:SettingRow Glyph="&#xE700;" Header="Compact spacing"
                                 Description="Reduce padding to fit more on screen.">
                <ToggleSwitch IsOn="{x:Bind ViewModel.UseCompactSpacing, Mode=TwoWay}" />
            </controls:SettingRow>

            <TextBlock Text="Notifications" Style="{StaticResource SectionHeaderStyle}" Margin="0,12,0,0" />

            <controls:SettingRow Glyph="&#xE715;" Header="Email notifications"
                                 Description="Get notified when a project changes status.">
                <ToggleSwitch IsOn="{x:Bind ViewModel.EmailNotifications, Mode=TwoWay}" />
            </controls:SettingRow>

            <controls:SettingRow Glyph="&#xE787;" Header="Weekly digest"
                                 Description="A Monday summary of portfolio progress.">
                <ToggleSwitch IsOn="{x:Bind ViewModel.WeeklyDigest, Mode=TwoWay}" />
            </controls:SettingRow>

            <TextBlock Text="About" Style="{StaticResource SectionHeaderStyle}" Margin="0,12,0,0" />

            <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                <Expander.Header>
                    <Grid ColumnSpacing="16" Padding="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <FontIcon Glyph="&#xE946;" FontSize="18" VerticalAlignment="Center"
                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                        <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="About Nimbus" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBlock Text="{x:Bind ViewModel.AppVersion}"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </Grid>
                </Expander.Header>
                <StackPanel Spacing="8" Padding="0,4">
                    <TextBlock Text="Built with WinUI 3 · .NET 8 · Windows App SDK · MVVM"
                               Style="{StaticResource BodyTextBlockStyle}" />
                    <TextBlock TextWrapping="Wrap"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Text="The UI (Nimbus.App) and the business logic (Nimbus.Core) are separate projects, so the views stay free of application logic." />
                </StackPanel>
            </Expander>

        </StackPanel>
    </ScrollViewer>
</Page>
