<Page
    x:Class="Nimbus.App.Views.AnalyticsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:tabsvm="using:Nimbus.App.ViewModels.Tabs"
    xmlns:tabs="using:Nimbus.App.Views.Tabs">

    <Grid Padding="36,28,36,36" RowSpacing="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="4">
            <TextBlock Text="Analytics" Style="{StaticResource PageTitleStyle}" />
            <TextBlock Text="Slice performance across revenue, audience and reliability."
                       Style="{StaticResource BodyTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </StackPanel>

        <!-- Vertical tabs (left) + content (right) -->
        <Grid Grid.Row="1" ColumnSpacing="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ListView x:Name="TabList" Grid.Column="0" Width="200"
                      SelectionMode="Single"
                      ItemsSource="{x:Bind ViewModel.Tabs}"
                      SelectedItem="{x:Bind ViewModel.SelectedTab, Mode=TwoWay}">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Margin" Value="0,2" />
                        <Setter Property="Padding" Value="12,10" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="tabsvm:TabViewModelBase">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <FontIcon Glyph="{x:Bind Glyph}" FontSize="16" />
                            <TextBlock Text="{x:Bind Title}" VerticalAlignment="Center" />
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <ContentControl Grid.Column="1"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch"
                            Content="{x:Bind ViewModel.SelectedTab, Mode=OneWay}">
                <ContentControl.ContentTemplateSelector>
                    <tabs:TabTemplateSelector>
                        <tabs:TabTemplateSelector.Overview>
                            <DataTemplate>
                                <tabs:OverviewTab />
                            </DataTemplate>
                        </tabs:TabTemplateSelector.Overview>
                        <tabs:TabTemplateSelector.Revenue>
                            <DataTemplate>
                                <tabs:RevenueTab />
                            </DataTemplate>
                        </tabs:TabTemplateSelector.Revenue>
                        <tabs:TabTemplateSelector.Audience>
                            <DataTemplate>
                                <tabs:AudienceTab />
                            </DataTemplate>
                        </tabs:TabTemplateSelector.Audience>
                        <tabs:TabTemplateSelector.Performance>
                            <DataTemplate>
                                <tabs:PerformanceTab />
                            </DataTemplate>
                        </tabs:TabTemplateSelector.Performance>
                    </tabs:TabTemplateSelector>
                </ContentControl.ContentTemplateSelector>
            </ContentControl>
        </Grid>
    </Grid>
</Page>
